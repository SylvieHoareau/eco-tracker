{# templates/eco_tracker/list.html.twig #}
{% extends 'base.html.twig' %}

{% block body %}

<div class="container mt-5 my-md-5" id="main-content">
    <h1 class="mb-4 text-center h2">🌱 <span class="visually-hidden">Plante : </span>Communauté Eco-Tracker</h1>

    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
        {% for user in users %}
            <article class="col">
                <div class="card h-100 shadow-sm">
                    <header class="card-header bg-success text-white d-flex justify-content-between align-items-center">
                        <h5 class="mb-0">{{ user.username }}</h5>
                        <span class="badge bg-light text-dark" aria-label="{{ user.actions|length }} gestes effectués">
                            {{ user.actions|length }} gestes
                        </span>
                    </header>
            
            <div class="card-body">
                <h6 class="h6 card-subtitle mb-3 text-secondary">Éco-gestes enregistrés :</h6>
                <ul class="list-group list-group-flush">
                    {% for action in user.actions %}
                        <li class="list-group-item d-flex justify-content-between align-items-center border-0 px-0">
                            {% if action.title is defined %}
                                <span class="text-wrap me-2">
                                    <span aria-hidden="true">✨</span> {{ action.title }}
                                </span>
                                <span class="badge bg-primary rounded-pill">
                                    -{{ action.carbonSaved }}g <span class="visually-hidden">de CO2 économisés</span>
                                </span>
                            {% else %}
                                <small class="text-danger">Erreur de donnée (ID: {{ action|slice(0,5) }}...)</small>
                            {% endif %}
                        </li>
                    {% else %}
                        <li class="list-group-item text-muted font-italic px-0">Aucun geste pour le moment.</li>
                    {% endfor %}
                </ul>
            </div>

            <div class="card-footer bg-transparent border-top-0 p-3">
                <a href="{{ path('user_add_action', {'id': user.id }) }}" 
                    class="btn btn-outline-success btn-sm w-100"
                    aria-label="Ajouter un nouveau geste pour l'utilisateur {{ user.username }}"
                >
                    ➕ Ajouter un geste
                </a>
            </div>
        {% endfor %}
    </div>
</div>
{% endblock %}