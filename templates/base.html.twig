<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        <title>{% block title %}Welcome!{% endblock %}</title>
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>⚫️</text><text y=%221.3em%22 x=%220.2em%22 font-size=%2276%22 fill=%22%23fff%22>sf</text></svg>">
        
        {# Bootstrap CDN #}
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
        
        {# CSS Custom #}
        <link rel="stylesheet" href="{{ asset('styles/app.css') }}">
        
        {# Une police moderne (Google Fonts) #}
        <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;800&display=swap" rel="stylesheet">
        {% block stylesheets %}
        {% endblock %}

        {% block javascripts %}
            {% block importmap %}{{ importmap('app') }}{% endblock %}
        {% endblock %}
    </head>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <body>
        {# 1. Lien d'évitement pour l'accessibilité #}
        <a class="visually-hidden-focusable" href="#main-content">Aller au contenu principal</a>

        <nav class="navbar navbar-expand-lg navbar-dark shadow-sm" style="background-color: var(--eco-primary);">
            <div class="container">
                {# Logo / Nom de l'app #}
                <a class="navbar-brand fw-bold d-flex align-items-center" href="{{ path('eco_list') }}">
                    <span class="me-2">🌱</span> EcoTracker
                </a>

                {# Bouton mobile (Hambuger) #}
                <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Basculer la navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                {# Liens de navigation #}
                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav ms-auto align-items-center">
                        <li class="nav-item">
                            <a class="nav-link {{ app.request.get('_route') == 'eco_list' ? 'active' : '' }}" href="{{ path('eco_list') }}">
                                Communauté
                            </a>
                        </li>
                        <li class="nav-item ms-lg-3 mt-2 mt-lg-0">
                            <a class="btn btn-accent fw-bold" href="{{ path('user_new') }}">
                                🚀 Rejoindre
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link {{ app.request.get('_route') == 'app_map' ? 'active' : '' }}" href="{{ path('app_map') }}">
                                🗺️ Carte Impact
                            </a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>

        <main class="container mt-4" id="main-content">
            {# --- BLOC DES MESSAGES FLASH À AJOUTER ICI --- #}
            {% for message in app.flashes('success') %}
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    {{ message }}
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            {% endfor %}

            {% for message in app.flashes('error') %}
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    {{ message }}
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            {% endfor %}
            {# -------------------------------------------- #}

            {% block body %}{% endblock %}
        </main>

        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    </body>
</html>
